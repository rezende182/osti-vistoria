# Copie para .env (não versionar secrets reais).

ENVIRONMENT=development
HOST=127.0.0.1
PORT=5000

MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=test_database
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

CORS_ORIGINS=*

BEHIND_PROXY=false
TRUSTED_HOSTS=

LOG_LEVEL=INFO
DEBUG_API_DOCS=false

# --- Exemplo produção (variáveis no painel PaaS) ---
