# Copie para .env ou .env.local
# Vercel: defina REACT_APP_BACKEND_URL nas Environment Variables do projeto (Production + Preview).
REACT_APP_BACKEND_URL=https://osti-vistoria.onrender.com
ENABLE_HEALTH_CHECK=false

# Firebase (Authentication — e-mail/senha)
# Obrigatórias para o SDK inicializar. Na Vercel: mesmas chaves + redeploy após alterar.
# Console: Firebase → Definições do projeto → Suas apps (código Web).
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_APP_ID=
# Recomendadas (mesmo snippet do Firebase)
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
